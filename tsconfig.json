{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmitOnError": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "lib": ["ES2020", "DOM"]
  },
  "include": ["src/**/*.ts"]
}